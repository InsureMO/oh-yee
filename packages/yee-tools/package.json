{
  "name": "@rainbow-oh/yee-tools",
  "version": "0.1.0",
  "description": "A modern, type-safe TypeScript utility library",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/InsureMO/oh-yee.git",
    "directory": "packages/yee-tools"
  },
  "homepage": "https://github.com/InsureMO/oh-yee/tree/main/packages/yee-tools#readme",
  "bugs": {
    "url": "https://github.com/InsureMO/oh-yee/issues"
  },
  "keywords": [
    "typescript",
    "utility",
    "tools",
    "string-utils",
    "number-utils",
    "date-utils",
    "security",
    "http-client",
    "i18n",
    "tree-shakeable"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./string": {
      "types": "./dist/esm/string/string-utils.d.ts",
      "import": "./dist/esm/string/string-utils.mjs",
      "require": "./dist/cjs/string/string-utils.cjs"
    },
    "./number": {
      "types": "./dist/esm/number/number-utils.d.ts",
      "import": "./dist/esm/number/number-utils.mjs",
      "require": "./dist/cjs/number/number-utils.cjs"
    },
    "./date": {
      "types": "./dist/esm/date/date-utils.d.ts",
      "import": "./dist/esm/date/date-utils.mjs",
      "require": "./dist/cjs/date/date-utils.cjs"
    },
    "./array": {
      "types": "./dist/esm/array/array-utils.d.ts",
      "import": "./dist/esm/array/array-utils.mjs",
      "require": "./dist/cjs/array/array-utils.cjs"
    },
    "./object": {
      "types": "./dist/esm/object/object-utils.d.ts",
      "import": "./dist/esm/object/object-utils.mjs",
      "require": "./dist/cjs/object/object-utils.cjs"
    },
    "./security": {
      "types": "./dist/esm/security/security-utils.d.ts",
      "import": "./dist/esm/security/security-utils.mjs",
      "require": "./dist/cjs/security/security-utils.cjs"
    },
    "./cookie": {
      "types": "./dist/esm/cookie/cookie-utils.d.ts",
      "import": "./dist/esm/cookie/cookie-utils.mjs",
      "require": "./dist/cjs/cookie/cookie-utils.cjs"
    },
    "./type": {
      "types": "./dist/esm/type/type-utils.d.ts",
      "import": "./dist/esm/type/type-utils.mjs",
      "require": "./dist/cjs/type/type-utils.cjs"
    },
    "./url": {
      "types": "./dist/esm/url/url-utils.d.ts",
      "import": "./dist/esm/url/url-utils.mjs",
      "require": "./dist/cjs/url/url-utils.cjs"
    },
    "./cache": {
      "types": "./dist/esm/cache/session-context.d.ts",
      "import": "./dist/esm/cache/session-context.mjs",
      "require": "./dist/cjs/cache/session-context.cjs"
    },
    "./cache/session": {
      "types": "./dist/esm/cache/session-context.d.ts",
      "import": "./dist/esm/cache/session-context.mjs",
      "require": "./dist/cjs/cache/session-context.cjs"
    },
    "./cache/local": {
      "types": "./dist/esm/cache/local-context.d.ts",
      "import": "./dist/esm/cache/local-context.mjs",
      "require": "./dist/cjs/cache/local-context.cjs"
    },
    "./cache/page": {
      "types": "./dist/esm/cache/page-context.d.ts",
      "import": "./dist/esm/cache/page-context.mjs",
      "require": "./dist/cjs/cache/page-context.cjs"
    },
    "./cache/store": {
      "types": "./dist/esm/cache/store-context.d.ts",
      "import": "./dist/esm/cache/store-context.mjs",
      "require": "./dist/cjs/cache/store-context.cjs"
    },
    "./config": {
      "types": "./dist/esm/config/config-provider.d.ts",
      "import": "./dist/esm/config/config-provider.mjs",
      "require": "./dist/cjs/config/config-provider.cjs"
    },
    "./config/provider": {
      "types": "./dist/esm/config/config-provider.d.ts",
      "import": "./dist/esm/config/config-provider.mjs",
      "require": "./dist/cjs/config/config-provider.cjs"
    },
    "./fetch": {
      "types": "./dist/esm/fetch/index.d.ts",
      "import": "./dist/esm/fetch/index.mjs",
      "require": "./dist/cjs/fetch/index.cjs"
    },
    "./i18n": {
      "types": "./dist/esm/i18n/i18n-utils.d.ts",
      "import": "./dist/esm/i18n/i18n-utils.mjs",
      "require": "./dist/cjs/i18n/i18n-utils.cjs"
    },
    "./codetable": {
      "types": "./dist/esm/codetable/index.d.ts",
      "import": "./dist/esm/codetable/index.mjs",
      "require": "./dist/cjs/codetable/index.cjs"
    },
    "./common": {
      "types": "./dist/esm/common/index.d.ts",
      "import": "./dist/esm/common/index.mjs",
      "require": "./dist/cjs/common/index.cjs"
    },
    "./umd": "./dist/umd/yee-tools.min.js"
  },
  "sideEffects": false,
  "files": [
    "dist/esm",
    "dist/cjs",
    "dist/umd",
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "README.md",
    "LICENSE",
    "API.md"
  ],
  "dependencies": {},
  "peerDependencies": {
    "dayjs": "^1.11.11"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && rollup -c",
    "build:prod": "cross-env NODE_ENV=production npm run build",
    "build:types": "tsc -p tsconfig.types.json",
    "build:all": "npm run build && npm run build:types",
    "prepublishOnly": "npm run build:all",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "npm run lint:es",
    "lint:es": "eslint \"{src,test}/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,less,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,less,json}\""
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@umijs/lint": "^4.5.3",
    "cross-env": "^7.0.3",
    "eslint": "^8.23.0",
    "fake-indexeddb": "^6.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rimraf": "^5.0.10",
    "rollup": "^4.22.4",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-filesize": "^10.0.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "ts-jest": "^29.2.5",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3"
  }
}
